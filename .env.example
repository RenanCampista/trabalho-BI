# Copie para .env se quiser centralizar a configuracao local.
# O pipeline tambem aceita argumentos via linha de comando.

# SQLite para demonstracao local
WAREHOUSE_URL=sqlite:///warehouse/bi_fundos.sqlite

# PostgreSQL opcional
# WAREHOUSE_URL=postgresql+psycopg2://usuario:senha@localhost:5432/bi_fundos

# Periodo padrao das fontes publicas e dos dados fake
START_YEAR=2021
END_YEAR=2026

# Reprodutibilidade e volume dos dados internos fake
FAKER_SEED=20261
N_CUSTOMERS=900
N_ACCOUNTS=1100
N_TRANSACTIONS=14000

# Tickers usados na comparacao de mercado
BCRI_TICKER=BCRI11.SA
IBOV_TICKER=^BVSP


# Quantidade de fundos CVM carregados, escolhidos por maior patrimonio liquido
MAX_PUBLIC_FUNDS=80

